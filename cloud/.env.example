# ===== 必需配置（必须在环境变量中设置）=====
INFLUXDB_TOKEN=your_influxdb_token
MQTT_PASS=your_mqtt_password

# ===== 可选配置（以下为默认值）=====

# MQTT配置
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=zhuxiangbo

# InfluxDB配置
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=influxdb_8KDcrG
INFLUXDB_BUCKET=influxdb_QPKwNw

# 钉钉机器人Webhook（不设置则不发送钉钉通知）
DINGTALK_WEBHOOK=

# 图片服务器URL（钉钉消息中图片的访问地址）
IMAGE_SERVER_URL=http://your_server_ip:9090
